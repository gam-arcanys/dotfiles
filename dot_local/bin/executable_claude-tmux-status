#!/usr/bin/env bash
# claude-tmux-status - Show Claude Code status in tmux status bar
# Reads state files from /tmp/claude-tmux-status/ written by Claude Code hooks

STATUS_DIR="/tmp/claude-tmux-status"

[ -d "$STATUS_DIR" ] || exit 0

needs_input=0
needs_permission=0
working=0

for f in "$STATUS_DIR"/%*; do
    [ -f "$f" ] || continue

    pane_id="$(basename "$f")"

    # Clean up stale files for panes that no longer exist
    if ! tmux display-message -t "$pane_id" -p '' 2>/dev/null; then
        rm -f "$f"
        continue
    fi

    state="$(cat "$f" 2>/dev/null)"
    case "$state" in
        needs_permission) needs_permission=$((needs_permission + 1)) ;;
        needs_input)      needs_input=$((needs_input + 1)) ;;
        working)          working=$((working + 1)) ;;
    esac
done

total=$((needs_input + needs_permission + working))
[ "$total" -eq 0 ] && exit 0

parts=""
if [ "$needs_permission" -gt 0 ]; then
    parts="${parts}#[fg=black,bg=red,bold] !${needs_permission} #[default]"
fi
if [ "$needs_input" -gt 0 ]; then
    parts="${parts}#[fg=black,bg=yellow,bold] ✦${needs_input} #[default]"
fi
if [ "$working" -gt 0 ]; then
    parts="${parts}#[fg=black,bg=green,bold] ●${working} #[default]"
fi

echo "${parts} "
