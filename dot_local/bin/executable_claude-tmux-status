#!/usr/bin/env bash
# claude-tmux-status - Show Claude Code status in tmux status bar
# Reads state files from /tmp/claude-tmux-status/ written by Claude Code hooks

STATUS_DIR="/tmp/claude-tmux-status"

[ -d "$STATUS_DIR" ] || exit 0

needs_input_panes=""
needs_permission_panes=""
working_panes=""

for f in "$STATUS_DIR"/%*; do
    [ -f "$f" ] || continue

    pane_id="$(basename "$f")"

    # Resolve pane ID to session:window.pane, also validates pane exists
    location="$(tmux display-message -t "$pane_id" -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)"
    if [ -z "$location" ]; then
        rm -f "$f"
        continue
    fi

    state="$(cat "$f" 2>/dev/null)"
    case "$state" in
        needs_permission)
            needs_permission_panes="${needs_permission_panes:+${needs_permission_panes},}${location}"
            ;;
        needs_input)
            needs_input_panes="${needs_input_panes:+${needs_input_panes},}${location}"
            ;;
        working)
            working_panes="${working_panes:+${working_panes},}${location}"
            ;;
    esac
done

[ -n "$needs_permission_panes" ] || [ -n "$needs_input_panes" ] || [ -n "$working_panes" ] || exit 0

parts=""
if [ -n "$needs_permission_panes" ]; then
    parts="${parts}#[fg=black,bg=red,bold] !${needs_permission_panes} #[default]"
fi
if [ -n "$needs_input_panes" ]; then
    parts="${parts}#[fg=black,bg=yellow,bold] ✦${needs_input_panes} #[default]"
fi
if [ -n "$working_panes" ]; then
    parts="${parts}#[fg=black,bg=green,bold] ●${working_panes} #[default]"
fi

echo "${parts} "
