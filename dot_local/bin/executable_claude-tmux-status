#!/usr/bin/env bash
# claude-tmux-status - Show Claude Code status in tmux status bar
# Reads state files from /tmp/claude-tmux-status/ written by Claude Code hooks

STATUS_DIR="/tmp/claude-tmux-status"

[ -d "$STATUS_DIR" ] || exit 0

parts=""

for f in "$STATUS_DIR"/%*; do
    [ -f "$f" ] || continue

    pane_id="$(basename "$f")"

    # Resolve pane ID to session:window.pane, also validates pane exists
    location="$(tmux display-message -t "$pane_id" -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)"
    if [ -z "$location" ]; then
        rm -f "$f"
        continue
    fi

    state="$(cat "$f" 2>/dev/null)"
    case "$state" in
        needs_permission)
            parts="${parts}#[fg=black,bg=red,bold] !${location} #[default] "
            ;;
        needs_input)
            parts="${parts}#[fg=black,bg=yellow,bold] ✦${location} #[default] "
            ;;
        working)
            parts="${parts}#[fg=black,bg=green,bold] ●${location} #[default] "
            ;;
    esac
done

[ -z "$parts" ] && exit 0

echo "${parts} "
